# ── LLM ──────────────────────────────────────────────────────────────────────
# Groq — free at https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Web Search ────────────────────────────────────────────────────────────────
# Tavily — free at https://app.tavily.com (1,000 searches/month)
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── News Data ─────────────────────────────────────────────────────────────────
# NewsData.io — free at https://newsdata.io (200 requests/day)
NEWSDATA_API_KEY=pub_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Database (Supabase) ───────────────────────────────────────────────────────
# Create a free project at https://supabase.com
# URL format: https://xxxxxxxxxxxx.supabase.co
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Found in: Project Settings → API → service_role key (not anon key)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxx

# ── Observability (LangSmith) ─────────────────────────────────────────────────
# Free at https://smith.langchain.com — set TRACING to false to disable
LANGCHAIN_API_KEY=lsv2_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGCHAIN_PROJECT=news-platform
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ── App Config ────────────────────────────────────────────────────────────────
SQLITE_DB_PATH=./checkpoints.db
FRONTEND_URL=http://localhost:3000

# ── AI News Briefing ──────────────────────────────────────────────────────────
# ElevenLabs — free at https://elevenlabs.io (10,000 chars/month free)
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# D-ID talking-head video — free trial at https://www.d-id.com
# IMPORTANT: This is NOT your raw D-ID API key.
# You must Base64-encode "your@email.com:your_api_key" first.
# Generate it: python -c "import base64; print(base64.b64encode(b'email:key').decode())"
# Leave empty to run in audio-only mode (D-ID is fully optional).
DID_API_KEY=

# ── Slack ─────────────────────────────────────────────────────────────────────
# Create a free workspace at slack.com, then go to api.slack.com/apps
# Create app → Incoming Webhooks → Add webhook to workspace → copy URL
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../xxxxxxx

# ── Notion MCP ────────────────────────────────────────────────────────────────
# Create integration at https://www.notion.so/my-integrations
# Then share your "Research Sessions" database with the integration
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Supabase Auth (JWT verification) ─────────────────────────────────────────
# Get this from: Supabase Dashboard → Project Settings → API → JWT Secret
# NOTE: This is the "Legacy JWT Secret" (HS256), NOT the service_role key or anon key.
# In the dashboard go to: Settings → JWT Keys → "Legacy JWT Secret" tab → copy the secret string.
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# ── Broadcast Analyzer (Whisper) ──────────────────────────────────────────────
# Model size: tiny | base | small | medium | large
# "base" is recommended — good accuracy, runs on CPU in ~1 min for a 5-min video
# "tiny" is fastest but less accurate; "small" is more accurate but slower
WHISPER_MODEL=small
