# ── Frontend Environment Variables ────────────────────────────────────────
# Copy this file to .env.local and fill in your values.

# Backend API URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Supabase (Auth) ────────────────────────────────────────────────────────
# Both values found in: Supabase Dashboard → Project Settings → API
# NEXT_PUBLIC_SUPABASE_URL   → "Project URL"  (https://xxxx.supabase.co)
# NEXT_PUBLIC_SUPABASE_ANON_KEY → "anon public" key (NOT the service_role key)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxx
